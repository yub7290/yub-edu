<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yub.edu.biz.mapper.EduQuestionKnowledgePointMapper">

    <resultMap id="EduQuestionKnowledgePointMap" type="com.yub.edu.biz.entity.EduQuestionKnowledgePoint">
        <id column="id" property="id"/>
        <result column="question_id" property="questionId"/>
        <result column="knowledge_point_id" property="knowledgePointId"/>
        <result column="sort" property="sort"/>
        <result column="create_time" property="createTime"/>
        <result column="create_by" property="createBy"/>
    </resultMap>

    <sql id="baseColumns">
        id, question_id, knowledge_point_id, sort, create_time, create_by
    </sql>

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO edu_question_knowledge_point (question_id, knowledge_point_id, sort, create_time, create_by)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.questionId}, #{item.knowledgePointId}, #{item.sort}, NOW(), #{item.createBy})
        </foreach>
    </insert>

    <delete id="deleteByQuestionId">
        DELETE FROM edu_question_knowledge_point WHERE question_id = #{questionId}
    </delete>

    <select id="selectKnowledgePointIdsByQuestionId" resultType="long">
        SELECT knowledge_point_id FROM edu_question_knowledge_point
        WHERE question_id = #{questionId}
        ORDER BY sort ASC
    </select>

</mapper>
